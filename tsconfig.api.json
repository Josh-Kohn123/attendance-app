{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist-api",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": ["api/**/*.ts", "lib/**/*.ts"],
  "references": [
    { "path": "./packages/shared" },
    { "path": "./packages/authz" },
    { "path": "./packages/db" }
  ]
}
