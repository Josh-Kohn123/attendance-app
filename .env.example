# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:your_password@localhost:5432/orbs_attendance?schema=public"

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth (Google OAuth) ─────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-strong-random-secret"
JWT_EXPIRES_IN="8h"

# ─── API ──────────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:5173"

# ─── Gmail (choose ONE auth method) ──────────────────────────
#
# Option A — App Password (simplest for personal/workspace accounts)
# 1. Enable 2FA on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Generate a password for "Mail" and paste it below
GMAIL_USER="your-address@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
GMAIL_FROM_NAME="Orbs Attendance"
#
# Option B — OAuth2 (recommended for production)
# Leave GMAIL_APP_PASSWORD blank and fill these in instead.
# Follow: https://developers.google.com/identity/protocols/oauth2
# GMAIL_OAUTH_CLIENT_ID="your-client-id.apps.googleusercontent.com"
# GMAIL_OAUTH_CLIENT_SECRET="your-client-secret"
# GMAIL_OAUTH_REFRESH_TOKEN="your-refresh-token"

# ─── App ──────────────────────────────────────────────────────
NODE_ENV="development"
DEFAULT_ORG_ID="00000000-0000-0000-0000-000000000001"
