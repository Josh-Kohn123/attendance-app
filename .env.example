# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:your_password@localhost:5432/orbs_attendance?schema=public"

# ─── Auth (Google OAuth) ─────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-strong-random-secret"
JWT_EXPIRES_IN="8h"

# ─── API ──────────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:5173"

# ─── Gmail (choose ONE auth method) ──────────────────────────
#
# Option A — App Password (simplest for personal/workspace accounts)
# 1. Enable 2FA on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Generate a password for "Mail" and paste it below
GMAIL_USER="your-address@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
GMAIL_FROM_NAME="Orbs Attendance"
#
# Option B — OAuth2 (recommended for production)
# Leave GMAIL_APP_PASSWORD blank and fill these in instead.
# Follow: https://developers.google.com/identity/protocols/oauth2
# GMAIL_OAUTH_CLIENT_ID="your-client-id.apps.googleusercontent.com"
# GMAIL_OAUTH_CLIENT_SECRET="your-client-secret"
# GMAIL_OAUTH_REFRESH_TOKEN="your-refresh-token"

# ─── App ──────────────────────────────────────────────────────
NODE_ENV="development"
DEFAULT_ORG_ID="00000000-0000-0000-0000-000000000001"

# ─── Daily Attendance Automation ─────────────────────────────
# Runs at end of workday (DAILY_ATTENDANCE_TIME) to auto-fill records.
# WFH days (Mon/Wed): mark PRESENT if no confirmed absence from digest.
# Office days (Sun/Tue/Thu): check HikVision, then email employee if unknown.
DAILY_ATTENDANCE_ENABLED="true"
DAILY_ATTENDANCE_TIME="17:00"
SYSTEM_USER_ID="00000000-0000-0000-0000-000000000000"

# ─── Calendar Digest ───────────────────────────────────────────
# Morning time to email the designated admin with today's calendar events.
# Admin must confirm changes via the review page before they are applied.
# Set the admin user via Administration → Policies in the UI.
CALENDAR_DIGEST_TIME="08:00"

# ─── Google Calendar (Shared Org Calendar) ───────────────────
# 1. Create a service account in Google Cloud Console
# 2. Enable the Google Calendar API
# 3. Download the JSON key and paste the full JSON below
# 4. Share your org's shared calendar with the service account email (read-only)
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"attendance@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'
GOOGLE_CALENDAR_ID="your-shared-calendar-id@group.calendar.google.com"

# ─── HikVision (Placeholder — uncomment when system is set up) ─
# HIKVISION_API_URL="https://your-hikvision-server/ISAPI"
# HIKVISION_API_KEY="your-api-key"
# HIKVISION_USERNAME="admin"
# HIKVISION_PASSWORD="password"
